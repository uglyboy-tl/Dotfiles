# sxhkd 快捷键配置

# === 通用应用 ===
# 终端
super + Return
	ghostty

# 应用启动器
super + r
	rofi -show drun

# 窗口切换
alt + Tab
	rofi -show window

# 文件管理器
super + e
	ghostty --x11-instance-name=yazi -e yazi

# 终端应用 (音乐/系统监控/新闻)
super + {m,h,n}
	command -v {ncmpcpp,btop,newsboat} >/dev/null && ghostty -e {ncmpcpp,btop,newsboat}

# 从剪贴板 URL 用 mpv 播放视频（需要 xclip）
super + v
	command -v xclip >/dev/null && mpv "$(xclip -selection clipboard -o 2>/dev/null)" || notify-send "需要安装 xclip: sudo apt install xclip"

# 蓝牙管理
super + b
	~/.local/bin/rofi-bluetooth

# 重载配置
super + Escape
	pkill -USR1 -x sxhkd

# === 音量控制 ===
# 音量 +/-/静音
XF86Audio{RaiseVolume,LowerVolume,Mute}
	~/.local/bin/barify v {i,d,m}

# === bspwm 窗管 ===
# 退出重启
super + alt + q
	bspc quit

# 关闭/强制关闭
super + {_,shift+}w
	bspc node -{c,k}

# 切换布局
super + shift + f
	bspc desktop -l next

# === 窗口状态 ===
# 平铺/伪平铺/浮动/全屏
super + {t,shift+t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# 浮动/平铺切换
super + space
	bspc node -t "~"{floating,tiled}

# === 桌面切换 ===
# 焦点/移动到桌面
super + {_,shift+}{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'
