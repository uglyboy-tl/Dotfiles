term = xterm-256color
# --- Typography ---
font-family = monospace
font-size = 11

# --- Theme and Colors ---
theme = Catppuccin Mocha

# --- Window and Appearance ---
background-opacity = 0.8
background-blur-radius = 10
background-opacity-cells = true
gtk-titlebar = false
window-padding-x = 8
window-padding-balance = true